# ─────────────────────────────────────────────────────────────────────────────
# Jira credentials (stored by the app in electron-store — NOT in this file at runtime)
# These are for reference / initial setup.
# ─────────────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your_jira_api_token_here

# ─────────────────────────────────────────────────────────────────────────────
# n8n
# ─────────────────────────────────────────────────────────────────────────────
N8N_URL=http://localhost:5678

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI (used by n8n workflow — configure inside n8n credentials)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
