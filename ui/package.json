{
  "name": "auto-code",
  "version": "1.0.0",
  "description": "Auto Code — AI-powered code generator (Electron + React + n8n + Jira)",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n WEBPACK,ELECTRON -c cyan,yellow \"npm run build:renderer -- --watch\" \"wait-on dist/index.html && electron . --dev\"",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "build": "npm run build:renderer -- --mode production && electron-builder --win --x64",
    "electron": "electron ."
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.1",
    "axios": "^1.6.5",
    "electron-store": "^7.0.3",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.0.4",
    "react-router-dom": "^6.21.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.8.1",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "build": {
    "appId": "com.aidev.assistant",
    "productName": "AI Dev Assistant",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "files": [
      "src/main/**/*",
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  }
}
